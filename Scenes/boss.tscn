[sub_resource type="GDScript" id="GDScript_odcco"]
script/source = "extends Node

# Declaração do sinal (Obrigatório na Godot 4 para evitar erros)
signal beat_changed(current_beat: float)

@export var bpm: float = 120.0
@export var start_at_beat: float = 40.0 # Mude no Inspector para testar partes específicas

@onready var audio_player = $AudioStreamPlayer

func _ready():
	# Converte a batida desejada para segundos
	# Ex: Se start_at_beat for 60.0 e o BPM for 120, o tempo será 30.0 segundos
	var start_time = (start_at_beat * 60.0) / bpm
	
	# Dá o play exatamente nos segundos calculados
	audio_player.play(start_time)

func _process(_delta):
	if audio_player.playing:
		# Posição exata do áudio + compensação de latência do hardware
		var time = audio_player.get_playback_position() + AudioServer.get_time_since_last_mix()
		time -= AudioServer.get_output_latency()
		
		var current_beat = (time * bpm) / 60.0
		emit_signal(\"beat_changed\", current_beat)
"

